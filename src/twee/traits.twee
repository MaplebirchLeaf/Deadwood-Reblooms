:: Deadwood Reblooms Traits Widgets [widget]

<<widget 'deadwood-reblooms-action-kick'>>
	<<if !["disabled", "hidden"].includes($transformationParts.traits.hooves)>>
		<<print either(
			maplebirch.t("deadwoodReblooms.combat.hoovesKick.1"),
			maplebirch.t("deadwoodReblooms.combat.hoovesKick.2"),
			maplebirch.t("deadwoodReblooms.combat.hoovesKick.3")
		)>><<defiance 15 _args[0]>>
	<<else>>
		<<actionskick _args[0]>><<defiance 5 _args[0]>>
	<</if>>
<</widget>>
