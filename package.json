{
  "name": "deadwood-reblooms",
  "version": "1.0.0",
  "private": true,
  "description": "DoL mod built on the maplebirch.",
  "author": "楓樺葉",
  "type": "module",
  "scripts": {
    "prep": "bun run scripts/prep.ts",
    "build": "bun run rspack -- build --mode=production",
    "build:dev": "bun run rspack -- build --mode=development",
    "build:all": "bun run prep && bun run build && bun run package",
    "package": "bun run scripts/package.ts",
    "package:zip": "bun run scripts/package.ts --zip-only",
    "package:modpack": "bun run scripts/package.ts --modpack-only",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.5",
    "@rspack/core": "^2.0.5",
    "@scml-maplebirch/types": "^3.2.5",
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "^1.3.14",
    "@types/jquery": "^4.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/json5": "^2.2.0",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.9.1",
    "adm-zip": "^0.5.17",
    "js-yaml": "^4.1.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "pkg-types": "^2.3.1",
    "spectrum-colorpicker": "^1.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "scml": {
    "nickName": {
      "en": "Deadwood Reblooms",
      "cn": "枯木逢春"
    },
    "dependenceInfo": [
      {
        "modName": "ModLoader",
        "version": ">=2.0.0"
      },
      {
        "modName": "ModLoaderGui",
        "version": ">=1.0.0"
      },
      {
        "modName": "ModSubUiAngularJs",
        "version": ">=1.0.0"
      },
      {
        "modName": "ConflictChecker",
        "version": ">=1.0.0"
      },
      {
        "modName": "BeautySelectorAddon",
        "version": ">=2.0.0"
      },
      {
        "modName": "ReplacePatcher",
        "version": ">=1.0.0"
      },
      {
        "modName": "TweeReplacer",
        "version": ">=1.0.0"
      },
      {
        "modName": "GameVersion",
        "version": ">=0.5.8.10"
      }
    ]
  }
}
